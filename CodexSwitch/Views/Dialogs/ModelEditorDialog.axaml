<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:CodexSwitch.ViewModels"
             xmlns:ui="using:CodexSwitch.Controls"
             xmlns:cui="using:CodexSwitchUI.Controls"
             xmlns:i18n="using:CodexSwitch.I18n"
             xmlns:lucide="using:Lucide.Avalonia"
             x:Class="CodexSwitch.Views.Dialogs.ModelEditorDialog"
             x:DataType="vm:MainWindowViewModel">
    <ui:CsDialog IsVisible="{Binding IsModelDialogOpen}">
        <Border Classes="dialog-card model-editor-card"
                HorizontalAlignment="Center"
                VerticalAlignment="Center">
            <Grid RowDefinitions="Auto,*,Auto">
                <Border Classes="dialog-header">
                    <Grid ColumnDefinitions="*,Auto" ColumnSpacing="14">
                        <StackPanel Spacing="4">
                            <ui:CsText Text="{Binding ModelDialogTitle}" Classes="title"/>
                            <ui:CsText Text="{i18n:Tr modelDialog.description}"
                                       Classes="muted"
                                       TextWrapping="Wrap"/>
                        </StackPanel>
                        <cui:CodexIconButton Grid.Column="1"
                                             Variant="Ghost"
                                             Command="{Binding CloseModelDialogCommand}"
                                             ToolTip.Tip="{i18n:Tr common.close}">
                            <lucide:LucideIcon Kind="X" Size="16" StrokeWidth="2"/>
                        </cui:CodexIconButton>
                    </Grid>
                </Border>

                <ScrollViewer Grid.Row="1"
                              VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled">
                    <StackPanel Classes="dialog-body-stack">
                        <Border Classes="dialog-section">
                            <Grid RowDefinitions="Auto,Auto,Auto"
                                  ColumnDefinitions="*,*,*"
                                  ColumnSpacing="12"
                                  RowSpacing="12">
                                <ui:CsText Text="{i18n:Tr modelDialog.basic}"
                                           Classes="heading"
                                           Grid.ColumnSpan="3"/>
                                <cui:CodexField Grid.Row="1" Label="{i18n:Tr modelDialog.modelId}">
                                    <cui:CodexTextBox Text="{Binding ModelEditorId}" PlaceholderText="claude-sonnet-4-5"/>
                                </cui:CodexField>
                                <cui:CodexField Grid.Row="1" Grid.Column="1" Label="{i18n:Tr modelDialog.displayName}">
                                    <cui:CodexTextBox Text="{Binding ModelEditorDisplayName}" PlaceholderText="Claude Sonnet 4.5"/>
                                </cui:CodexField>
                                <cui:CodexField Grid.Row="1" Grid.Column="2" Label="{i18n:Tr modelDialog.iconSlug}">
                                    <cui:CodexTextBox Text="{Binding ModelEditorIconSlug}" PlaceholderText="claude"/>
                                </cui:CodexField>
                                <cui:CodexField Grid.Row="2" Grid.ColumnSpan="3" Label="{i18n:Tr modelDialog.aliases}">
                                    <cui:CodexTextBox Text="{Binding ModelEditorAliases}" PlaceholderText="claude-sonnet*, claude-4*"/>
                                </cui:CodexField>
                            </Grid>
                        </Border>

                        <Border Classes="dialog-section">
                            <Grid RowDefinitions="Auto,Auto,Auto"
                                  ColumnDefinitions="*,*,*"
                                  ColumnSpacing="12"
                                  RowSpacing="12">
                                <Grid Grid.ColumnSpan="3" ColumnDefinitions="*,Auto">
                                    <ui:CsText Text="{i18n:Tr modelDialog.inputCachePricing}" Classes="heading"/>
                                    <ui:CsBadge Grid.Column="1">
                                        <ui:CsText Text="{Binding PricingUnitText}" Classes="muted"/>
                                    </ui:CsBadge>
                                </Grid>
                                <cui:CodexField Grid.Row="1" Label="{i18n:Tr modelDialog.inputTierLimit}">
                                    <cui:CodexTextBox Text="{Binding ModelEditorInputTierLimit}" PlaceholderText="{i18n:Tr modelDialog.placeholderFlat}"/>
                                </cui:CodexField>
                                <cui:CodexField Grid.Row="1" Grid.Column="1" Label="{i18n:Tr modelDialog.inputPrice}">
                                    <cui:CodexTextBox Text="{Binding ModelEditorInputPrice}"/>
                                </cui:CodexField>
                                <cui:CodexField Grid.Row="1" Grid.Column="2" Label="{i18n:Tr modelDialog.inputOverCap}">
                                    <cui:CodexTextBox Text="{Binding ModelEditorInputOverflowPrice}"/>
                                </cui:CodexField>
                                <cui:CodexField Grid.Row="2" Label="{i18n:Tr modelDialog.cacheReadPrice}">
                                    <cui:CodexTextBox Text="{Binding ModelEditorCachedInputPrice}"/>
                                </cui:CodexField>
                                <cui:CodexField Grid.Row="2" Grid.Column="1" Label="{i18n:Tr modelDialog.cacheCreationPrice}">
                                    <cui:CodexTextBox Text="{Binding ModelEditorCacheCreationInputPrice}"/>
                                </cui:CodexField>
                                <Border Grid.Row="2"
                                        Grid.Column="2"
                                        Classes="dialog-note"
                                        VerticalAlignment="Bottom">
                                    <StackPanel Spacing="3">
                                        <ui:CsText Text="{i18n:Tr modelDialog.claudeCacheWrite}"
                                                   FontWeight="SemiBold"
                                                   FontSize="12"/>
                                        <ui:CsText Text="{i18n:Tr modelDialog.claudeCacheDescription}"
                                                   Classes="muted"
                                                   TextWrapping="Wrap"/>
                                    </StackPanel>
                                </Border>
                            </Grid>
                        </Border>

                        <Border Classes="dialog-section">
                            <Grid RowDefinitions="Auto,Auto,Auto"
                                  ColumnDefinitions="*,*,*"
                                  ColumnSpacing="12"
                                  RowSpacing="12">
                                <ui:CsText Text="{i18n:Tr modelDialog.outputMultiplier}"
                                           Classes="heading"
                                           Grid.ColumnSpan="3"/>
                                <cui:CodexField Grid.Row="1" Label="{i18n:Tr modelDialog.outputTierLimit}">
                                    <cui:CodexTextBox Text="{Binding ModelEditorOutputTierLimit}" PlaceholderText="{i18n:Tr modelDialog.placeholderFlat}"/>
                                </cui:CodexField>
                                <cui:CodexField Grid.Row="1" Grid.Column="1" Label="{i18n:Tr modelDialog.outputPrice}">
                                    <cui:CodexTextBox Text="{Binding ModelEditorOutputPrice}"/>
                                </cui:CodexField>
                                <cui:CodexField Grid.Row="1" Grid.Column="2" Label="{i18n:Tr modelDialog.outputOverCap}">
                                    <cui:CodexTextBox Text="{Binding ModelEditorOutputOverflowPrice}"/>
                                </cui:CodexField>
                                <cui:CodexField Grid.Row="2" Label="{i18n:Tr modelDialog.fastMultiplierOverride}">
                                    <cui:CodexTextBox Text="{Binding ModelEditorFastMultiplierOverride}" PlaceholderText="{i18n:Tr modelDialog.placeholderGlobal}"/>
                                </cui:CodexField>
                            </Grid>
                        </Border>
                    </StackPanel>
                </ScrollViewer>

                <Border Grid.Row="2" Classes="dialog-footer">
                    <StackPanel Orientation="Horizontal"
                                HorizontalAlignment="Right"
                                Spacing="10">
                        <cui:CodexButton Variant="Outline"
                                         Size="Small"
                                         Command="{Binding CloseModelDialogCommand}"
                                         Content="{i18n:Tr common.cancel}"/>
                        <cui:CodexButton Size="Small"
                                         Command="{Binding SaveModelCommand}"
                                         Content="{i18n:Tr modelDialog.save}">
                            <cui:CodexButton.LeadingIcon>
                                <lucide:LucideIcon Kind="Save" Size="14" StrokeWidth="2"/>
                            </cui:CodexButton.LeadingIcon>
                        </cui:CodexButton>
                    </StackPanel>
                </Border>
            </Grid>
        </Border>
    </ui:CsDialog>
</UserControl>
