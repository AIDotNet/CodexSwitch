<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:CodexSwitch.ViewModels"
             xmlns:ui="using:CodexSwitchUI.Controls"
             xmlns:text="using:CodexSwitchUI.Primitives"
             xmlns:i18n="using:CodexSwitch.I18n"
             xmlns:lucide="using:Lucide.Avalonia"
             x:Class="CodexSwitch.Views.Pages.UsagePage"
             x:DataType="vm:MainWindowViewModel">
    <UserControl.Styles>
        <Style Selector="TextBlock.table-strong">
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="TextTrimming" Value="CharacterEllipsis"/>
        </Style>
        <Style Selector="TextBlock.table-muted">
            <Setter Property="Foreground" Value="{DynamicResource CodexSwitch.MutedForegroundBrush}"/>
            <Setter Property="TextTrimming" Value="CharacterEllipsis"/>
        </Style>
    </UserControl.Styles>

    <ScrollViewer>
        <Grid Margin="24,12,24,28"
              RowDefinitions="Auto,Auto,Auto,Auto"
              RowSpacing="18">
            <ui:CodexSection Title="{i18n:Tr usage.logs.title}"
                             Description="{i18n:Tr usage.logs.description}">
                <ui:CodexSection.Actions>
                    <ui:CodexButton Variant="Outline"
                                    Size="Small"
                                    Command="{Binding RefreshUsageCommand}">
                        <ui:CodexButton.LeadingIcon>
                            <lucide:LucideIcon Kind="RefreshCw" Size="14" StrokeWidth="2"/>
                        </ui:CodexButton.LeadingIcon>
                        <TextBlock Text="{Binding UsageRefreshButtonText}"/>
                    </ui:CodexButton>
                </ui:CodexSection.Actions>
            </ui:CodexSection>

            <Grid Grid.Row="1"
                  ColumnDefinitions="*,Auto"
                  ColumnSpacing="16">
                <WrapPanel>
                    <ui:CodexField Label="{i18n:Tr usage.filter.provider}"
                                   MinWidth="220"
                                   Margin="0,0,14,10">
                        <ui:CodexSelect ItemsSource="{Binding UsageFilterProviderOptions}"
                                        SelectedValue="{Binding SelectedUsageFilterProvider, Mode=TwoWay}"
                                        SelectedValueBinding="{Binding Value}"
                                        MinWidth="220"
                                        Size="Small">
                            <ui:CodexSelect.ItemTemplate>
                                <DataTemplate x:DataType="vm:UsageFilterOption">
                                    <TextBlock Text="{Binding DisplayName}"
                                               TextTrimming="CharacterEllipsis"/>
                                </DataTemplate>
                            </ui:CodexSelect.ItemTemplate>
                        </ui:CodexSelect>
                    </ui:CodexField>
                    <ui:CodexField Label="{i18n:Tr usage.filter.model}"
                                   MinWidth="260"
                                   Margin="0,0,14,10">
                        <ui:CodexSelect ItemsSource="{Binding UsageFilterModelOptions}"
                                        SelectedValue="{Binding SelectedUsageFilterModel, Mode=TwoWay}"
                                        SelectedValueBinding="{Binding Value}"
                                        MinWidth="260"
                                        Size="Small">
                            <ui:CodexSelect.ItemTemplate>
                                <DataTemplate x:DataType="vm:UsageFilterOption">
                                    <TextBlock Text="{Binding DisplayName}"
                                               TextTrimming="CharacterEllipsis"/>
                                </DataTemplate>
                            </ui:CodexSelect.ItemTemplate>
                        </ui:CodexSelect>
                    </ui:CodexField>
                </WrapPanel>

                <StackPanel Grid.Column="1"
                            Spacing="6"
                            VerticalAlignment="Top">
                    <text:CodexText Text="{Binding UsageRangeCaption}"
                                    Role="Muted"
                                    HorizontalAlignment="Right"/>
                    <ui:CodexSegmentedControl>
                        <StackPanel Orientation="Horizontal" Spacing="4">
                            <ui:CodexSegmentedButton IsSelected="{Binding IsUsageRange24HoursSelected}"
                                                     Command="{Binding SelectUsageRangeCommand}"
                                                     CommandParameter="Last24Hours"
                                                     Content="{i18n:Tr usage.range.24h}"/>
                            <ui:CodexSegmentedButton IsSelected="{Binding IsUsageRange7DaysSelected}"
                                                     Command="{Binding SelectUsageRangeCommand}"
                                                     CommandParameter="Last7Days"
                                                     Content="{i18n:Tr usage.range.7d}"/>
                            <ui:CodexSegmentedButton IsSelected="{Binding IsUsageRange30DaysSelected}"
                                                     Command="{Binding SelectUsageRangeCommand}"
                                                     CommandParameter="Last30Days"
                                                     Content="{i18n:Tr usage.range.30d}"/>
                        </StackPanel>
                    </ui:CodexSegmentedControl>
                </StackPanel>
            </Grid>

            <ui:CodexPinnedTable Grid.Row="2"
                                 ItemsSource="{Binding UsageLogRows}"
                                 IsCompact="True"
                                 IsLoading="{Binding IsUsageRefreshing}"
                                 TransitionKey="{Binding UsageLogTableTransitionKey}"
                                 StartColumnWidth="88"
                                 EndColumnWidth="52"
                                 MiddleMinWidth="954">
                <ui:CodexPinnedTable.StartHeader>
                    <ui:CodexTableHead Content="{i18n:Tr usage.table.time}" MinWidth="0" Padding="6,6"/>
                </ui:CodexPinnedTable.StartHeader>
                <ui:CodexPinnedTable.MiddleHeader>
                    <Grid ColumnDefinitions="142,160,92,94,102,86,92,92,92">
                        <ui:CodexTableHead Content="{i18n:Tr usage.table.provider}" MinWidth="142"/>
                        <ui:CodexTableHead Grid.Column="1" Content="{i18n:Tr usage.table.model}" MinWidth="160"/>
                        <ui:CodexTableHead Grid.Column="2" Content="{i18n:Tr usage.table.input}" MinWidth="92"/>
                        <ui:CodexTableHead Grid.Column="3" Content="{i18n:Tr usage.table.cacheHit}" MinWidth="94"/>
                        <ui:CodexTableHead Grid.Column="4" Content="{i18n:Tr usage.table.cacheWrite}" MinWidth="102"/>
                        <ui:CodexTableHead Grid.Column="5" Content="{i18n:Tr usage.table.output}" MinWidth="86"/>
                        <ui:CodexTableHead Grid.Column="6" Content="{i18n:Tr usage.table.outputTps}" MinWidth="92"/>
                        <ui:CodexTableHead Grid.Column="7" Content="{i18n:Tr usage.table.cost}" MinWidth="92"/>
                        <ui:CodexTableHead Grid.Column="8" Content="{i18n:Tr usage.table.duration}" MinWidth="92"/>
                    </Grid>
                </ui:CodexPinnedTable.MiddleHeader>
                <ui:CodexPinnedTable.EndHeader>
                    <ui:CodexTableHead Content="{i18n:Tr usage.table.status}" MinWidth="0" Padding="6,6"/>
                </ui:CodexPinnedTable.EndHeader>

                <ui:CodexPinnedTable.StartCellTemplate>
                    <DataTemplate x:DataType="vm:UsageLogItem">
                        <ui:CodexTableRow>
                            <ui:CodexTableCell MinWidth="0" Padding="6,6">
                                <TextBlock Text="{Binding Time}" Classes="table-strong"/>
                            </ui:CodexTableCell>
                        </ui:CodexTableRow>
                    </DataTemplate>
                </ui:CodexPinnedTable.StartCellTemplate>

                <ui:CodexPinnedTable.MiddleCellTemplate>
                    <DataTemplate x:DataType="vm:UsageLogItem">
                        <ui:CodexTableRow>
                            <Grid ColumnDefinitions="142,160,92,94,102,86,92,92,92">
                                <ui:CodexTableCell MinWidth="142">
                                    <ui:CodexBadge Variant="Secondary" Padding="8,3">
                                        <TextBlock Text="{Binding Provider}" FontSize="12" FontWeight="SemiBold" TextTrimming="CharacterEllipsis"/>
                                    </ui:CodexBadge>
                                </ui:CodexTableCell>
                                <ui:CodexTableCell Grid.Column="1" MinWidth="160">
                                    <TextBlock Text="{Binding Model}" Classes="table-strong" Foreground="#C7D2FE"/>
                                </ui:CodexTableCell>
                                <ui:CodexTableCell Grid.Column="2" MinWidth="92">
                                    <TextBlock Text="{Binding Input}" Classes="table-strong"/>
                                </ui:CodexTableCell>
                                <ui:CodexTableCell Grid.Column="3" MinWidth="94">
                                    <TextBlock Text="{Binding CachedInput}" Classes="table-strong" Foreground="#C4B5FD"/>
                                </ui:CodexTableCell>
                                <ui:CodexTableCell Grid.Column="4" MinWidth="102">
                                    <TextBlock Text="{Binding CacheCreationInput}" Classes="table-strong" Foreground="#FCD34D"/>
                                </ui:CodexTableCell>
                                <ui:CodexTableCell Grid.Column="5" MinWidth="86">
                                    <TextBlock Text="{Binding Output}" Classes="table-strong" Foreground="#86EFAC"/>
                                </ui:CodexTableCell>
                                <ui:CodexTableCell Grid.Column="6" MinWidth="92">
                                    <TextBlock Text="{Binding OutputTps}" Classes="table-strong" Foreground="#FDE047"/>
                                </ui:CodexTableCell>
                                <ui:CodexTableCell Grid.Column="7" MinWidth="92">
                                    <TextBlock Text="{Binding Cost}" Classes="table-strong"/>
                                </ui:CodexTableCell>
                                <ui:CodexTableCell Grid.Column="8" MinWidth="92">
                                    <TextBlock Text="{Binding Duration}" Classes="table-muted"/>
                                </ui:CodexTableCell>
                            </Grid>
                        </ui:CodexTableRow>
                    </DataTemplate>
                </ui:CodexPinnedTable.MiddleCellTemplate>

                <ui:CodexPinnedTable.EndCellTemplate>
                    <DataTemplate x:DataType="vm:UsageLogItem">
                        <ui:CodexTableRow>
                            <ui:CodexTableCell MinWidth="0" Padding="6,6">
                                <Border Background="{Binding StatusBackground}"
                                        BorderBrush="{Binding StatusBorder}"
                                        BorderThickness="1"
                                        CornerRadius="6"
                                        Padding="6,3"
                                        HorizontalAlignment="Left">
                                    <TextBlock Text="{Binding Status}"
                                               Foreground="{Binding StatusForeground}"
                                               FontSize="12"
                                               FontWeight="SemiBold"/>
                                </Border>
                            </ui:CodexTableCell>
                        </ui:CodexTableRow>
                    </DataTemplate>
                </ui:CodexPinnedTable.EndCellTemplate>
            </ui:CodexPinnedTable>

            <Grid Grid.Row="3"
                  ColumnDefinitions="*,Auto"
                  ColumnSpacing="16">
                <StackPanel Orientation="Horizontal"
                            Spacing="8">
                    <ui:CodexIconButton Command="{Binding PreviousUsageLogPageCommand}"
                                        IsEnabled="{Binding CanGoToPreviousUsageLogPage}"
                                        ToolTip.Tip="{i18n:Tr usage.pagination.previous}">
                        <lucide:LucideIcon Kind="ChevronLeft" Size="16" StrokeWidth="2"/>
                    </ui:CodexIconButton>
                    <ui:CodexSegmentedControl VerticalAlignment="Center">
                        <ItemsControl ItemsSource="{Binding UsageLogPageOptions}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <StackPanel Orientation="Horizontal" Spacing="4"/>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate x:DataType="vm:UsageLogPageOption">
                                    <ui:CodexSegmentedButton IsSelected="{Binding IsSelected}"
                                                             Command="{Binding SelectCommand}"
                                                             CommandParameter="{Binding PageNumber}"
                                                             Content="{Binding DisplayName}"/>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ui:CodexSegmentedControl>
                    <ui:CodexIconButton Command="{Binding NextUsageLogPageCommand}"
                                        IsEnabled="{Binding CanGoToNextUsageLogPage}"
                                        ToolTip.Tip="{i18n:Tr usage.pagination.next}">
                        <lucide:LucideIcon Kind="ChevronRight" Size="16" StrokeWidth="2"/>
                    </ui:CodexIconButton>
                </StackPanel>
                <text:CodexText Grid.Column="1"
                                Text="{Binding UsageLogPageCaption}"
                                Role="Muted"
                                VerticalAlignment="Center"/>
            </Grid>
        </Grid>
    </ScrollViewer>
</UserControl>
