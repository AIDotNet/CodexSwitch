<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:CodexSwitch.ViewModels"
             xmlns:ui="using:CodexSwitchUI.Controls"
             xmlns:text="using:CodexSwitchUI.Primitives"
             xmlns:i18n="using:CodexSwitch.I18n"
             xmlns:lucide="using:Lucide.Avalonia"
             x:Class="CodexSwitch.Views.Pages.CodexSessionsPage"
             x:DataType="vm:MainWindowViewModel">
    <UserControl.Styles>
        <Style Selector="Border.session-panel">
            <Setter Property="Background" Value="{DynamicResource CodexSwitch.CardBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource CodexSwitch.BorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="{DynamicResource CodexSwitch.RadiusLg}"/>
            <Setter Property="Padding" Value="18"/>
        </Style>
        <Style Selector="Border.session-focus">
            <Setter Property="MinHeight" Value="292"/>
        </Style>
        <Style Selector="Border.session-target">
            <Setter Property="Padding" Value="16"/>
            <Setter Property="Background" Value="{DynamicResource CodexSwitch.MutedBrush}"/>
            <Setter Property="CornerRadius" Value="{DynamicResource CodexSwitch.RadiusMd}"/>
        </Style>
        <Style Selector="Border.session-metric">
            <Setter Property="Padding" Value="12"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="{DynamicResource CodexSwitch.BorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="{DynamicResource CodexSwitch.RadiusMd}"/>
        </Style>
        <Style Selector="Border.session-provider-row">
            <Setter Property="Padding" Value="14,13"/>
            <Setter Property="BorderBrush" Value="{DynamicResource CodexSwitch.BorderBrush}"/>
            <Setter Property="BorderThickness" Value="0,0,0,1"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Transitions">
                <Transitions>
                    <BrushTransition Property="Background" Duration="0:0:0.14"/>
                    <BrushTransition Property="BorderBrush" Duration="0:0:0.14"/>
                </Transitions>
            </Setter>
        </Style>
        <Style Selector="Border.session-provider-row:pointerover">
            <Setter Property="Background" Value="{DynamicResource CodexSwitch.MutedBrush}"/>
        </Style>
        <Style Selector="Border.session-provider-row.current">
            <Setter Property="Background" Value="{DynamicResource CodexSwitch.ProviderCardActiveBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource CodexSwitch.ProviderCardActiveBorderBrush}"/>
        </Style>
        <Style Selector="Border.status-dot">
            <Setter Property="Width" Value="7"/>
            <Setter Property="Height" Value="7"/>
            <Setter Property="CornerRadius" Value="999"/>
            <Setter Property="Background" Value="{DynamicResource CodexSwitch.WarningBrush}"/>
        </Style>
        <Style Selector="Border.status-dot.current">
            <Setter Property="Background" Value="{DynamicResource CodexSwitch.SuccessBrush}"/>
        </Style>
        <Style Selector="TextBlock.session-number">
            <Setter Property="FontSize" Value="28"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="{DynamicResource CodexSwitch.ForegroundBrush}"/>
            <Setter Property="TextTrimming" Value="CharacterEllipsis"/>
        </Style>
        <Style Selector="TextBlock.session-label">
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Foreground" Value="{DynamicResource CodexSwitch.MutedForegroundBrush}"/>
            <Setter Property="TextTrimming" Value="CharacterEllipsis"/>
        </Style>
    </UserControl.Styles>

    <ScrollViewer>
        <Grid Margin="24,12,24,28"
              RowDefinitions="Auto,*"
              RowSpacing="18">
            <ui:CodexSection Title="{i18n:Tr codexSessions.title}"
                             Description="{Binding CodexSessionStatusMessage}">
                <ui:CodexSection.Actions>
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <ui:CodexButton Variant="Outline"
                                        Size="Small"
                                        Command="{Binding RefreshCodexSessionsCommand}">
                            <ui:CodexButton.LeadingIcon>
                                <lucide:LucideIcon Kind="RefreshCw" Size="14" StrokeWidth="2"/>
                            </ui:CodexButton.LeadingIcon>
                            <TextBlock Text="{Binding CodexSessionRefreshButtonText}"/>
                        </ui:CodexButton>
                        <ui:CodexButton Size="Small"
                                        IsEnabled="{Binding CanMigrateCodexSessions}"
                                        Command="{Binding MigrateCodexSessionsCommand}">
                            <ui:CodexButton.LeadingIcon>
                                <lucide:LucideIcon Kind="MoveRight" Size="14" StrokeWidth="2"/>
                            </ui:CodexButton.LeadingIcon>
                            <TextBlock Text="{Binding CodexSessionMigrationButtonText}"/>
                        </ui:CodexButton>
                        <ui:CodexButton Variant="Outline"
                                        Size="Small"
                                        IsEnabled="{Binding CanRestoreCodexSessions}"
                                        Command="{Binding RestoreCodexSessionsCommand}">
                            <ui:CodexButton.LeadingIcon>
                                <lucide:LucideIcon Kind="History" Size="14" StrokeWidth="2"/>
                            </ui:CodexButton.LeadingIcon>
                            <TextBlock Text="{Binding CodexSessionRestoreButtonText}"/>
                        </ui:CodexButton>
                    </StackPanel>
                </ui:CodexSection.Actions>
            </ui:CodexSection>

            <Grid Grid.Row="1"
                  ColumnDefinitions="0.92*,1.08*"
                  ColumnSpacing="18">
                <Border Classes="session-panel session-focus">
                    <Grid RowDefinitions="Auto,Auto,*,Auto"
                          RowSpacing="16">
                        <StackPanel Spacing="4">
                            <text:CodexText Text="{i18n:Tr codexSessions.migrationTarget}"
                                            Role="Muted"/>
                            <TextBlock Text="{Binding CodexSessionCurrentProvider}"
                                       FontSize="32"
                                       FontWeight="SemiBold"
                                       TextTrimming="CharacterEllipsis"/>
                        </StackPanel>

                        <Border Grid.Row="1"
                                Classes="session-target">
                            <Grid ColumnDefinitions="Auto,*"
                                  ColumnSpacing="12">
                                <Border Width="38"
                                        Height="38"
                                        CornerRadius="10"
                                        Background="{DynamicResource CodexSwitch.PrimaryBrush}">
                                    <lucide:LucideIcon Kind="Route"
                                                       Size="19"
                                                       StrokeWidth="2"
                                                       Foreground="{DynamicResource CodexSwitch.PrimaryForegroundBrush}"
                                                       HorizontalAlignment="Center"
                                                       VerticalAlignment="Center"/>
                                </Border>
                                <StackPanel Grid.Column="1" Spacing="3">
                                    <TextBlock Text="{i18n:Tr codexSessions.description}"
                                               TextWrapping="Wrap"
                                               LineHeight="18"
                                               FontSize="13"/>
                                    <text:CodexText Text="{Binding CodexSessionCurrentProviderDetail}"
                                                    Role="Muted"/>
                                </StackPanel>
                            </Grid>
                        </Border>

                        <Grid Grid.Row="2"
                              ColumnDefinitions="*,*,*"
                              RowDefinitions="Auto,Auto"
                              ColumnSpacing="10"
                              RowSpacing="10">
                            <Border Classes="session-metric">
                                <StackPanel Spacing="3">
                                    <TextBlock Text="{Binding CodexSessionTotalCount}"
                                               Classes="session-number"/>
                                    <TextBlock Text="{i18n:Tr codexSessions.totalSessions}"
                                               Classes="session-label"/>
                                </StackPanel>
                            </Border>
                            <Border Grid.Column="1"
                                    Classes="session-metric">
                                <StackPanel Spacing="3">
                                    <TextBlock Text="{Binding CodexSessionMigratableCount}"
                                               Classes="session-number"/>
                                    <TextBlock Text="{i18n:Tr codexSessions.migratable}"
                                               Classes="session-label"/>
                                </StackPanel>
                            </Border>
                            <Border Grid.Column="2"
                                    Classes="session-metric">
                                <StackPanel Spacing="3">
                                    <TextBlock Text="{Binding CodexSessionRestorableCount}"
                                               Classes="session-number"/>
                                    <TextBlock Text="{i18n:Tr codexSessions.restorable}"
                                               Classes="session-label"/>
                                </StackPanel>
                            </Border>
                            <Border Grid.Row="1"
                                    Grid.ColumnSpan="3"
                                    Classes="session-metric">
                                <StackPanel Spacing="3">
                                    <TextBlock Text="{Binding CodexSessionTotalDetail}"
                                               FontSize="13"
                                               FontWeight="SemiBold"
                                               TextTrimming="CharacterEllipsis"/>
                                    <text:CodexText Text="{Binding CodexSessionMigratableDetail}"
                                                    Role="Muted"/>
                                    <text:CodexText Text="{Binding CodexSessionRestorableDetail}"
                                                    Role="Muted"/>
                                </StackPanel>
                            </Border>
                        </Grid>

                        <Grid Grid.Row="3"
                              ColumnDefinitions="*,Auto"
                              ColumnSpacing="10">
                            <text:CodexText Text="{Binding CodexSessionStatusMessage}"
                                            Role="Muted"
                                            TextWrapping="Wrap"
                                            VerticalAlignment="Center"/>
                            <StackPanel Grid.Column="1"
                                        Orientation="Horizontal"
                                        Spacing="8">
                                <ui:CodexButton Variant="Outline"
                                                Size="Small"
                                                IsEnabled="{Binding CanRestoreCodexSessions}"
                                                Command="{Binding RestoreCodexSessionsCommand}">
                                    <ui:CodexButton.LeadingIcon>
                                        <lucide:LucideIcon Kind="History" Size="14" StrokeWidth="2"/>
                                    </ui:CodexButton.LeadingIcon>
                                    <TextBlock Text="{Binding CodexSessionRestoreButtonText}"/>
                                </ui:CodexButton>
                                <ui:CodexButton Size="Small"
                                                IsEnabled="{Binding CanMigrateCodexSessions}"
                                                Command="{Binding MigrateCodexSessionsCommand}">
                                    <ui:CodexButton.LeadingIcon>
                                        <lucide:LucideIcon Kind="MoveRight" Size="14" StrokeWidth="2"/>
                                    </ui:CodexButton.LeadingIcon>
                                    <TextBlock Text="{Binding CodexSessionMigrationButtonText}"/>
                                </ui:CodexButton>
                            </StackPanel>
                        </Grid>
                    </Grid>
                </Border>

                <Border Grid.Column="1"
                        Classes="session-panel">
                    <Grid RowDefinitions="Auto,*"
                          RowSpacing="12">
                        <Grid ColumnDefinitions="*,Auto">
                            <StackPanel Spacing="3">
                                <TextBlock Text="{i18n:Tr codexSessions.providerBreakdown}"
                                           FontWeight="SemiBold"
                                           FontSize="16"/>
                                <text:CodexText Text="{i18n:Tr codexSessions.providerBreakdownDescription}"
                                                Role="Muted"/>
                            </StackPanel>
                            <ui:CodexButton Grid.Column="1"
                                            Variant="Ghost"
                                            Size="Small"
                                            Command="{Binding RefreshCodexSessionsCommand}">
                                <ui:CodexButton.LeadingIcon>
                                    <lucide:LucideIcon Kind="RefreshCw" Size="14" StrokeWidth="2"/>
                                </ui:CodexButton.LeadingIcon>
                                <TextBlock Text="{Binding CodexSessionRefreshButtonText}"/>
                            </ui:CodexButton>
                        </Grid>

                        <ItemsControl Grid.Row="1"
                                      ItemsSource="{Binding CodexSessionProviderRows}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate x:DataType="vm:CodexSessionProviderItem">
                                    <Border Classes="session-provider-row"
                                            Classes.current="{Binding IsManagedProvider}">
                                        <Grid RowDefinitions="Auto,Auto"
                                              RowSpacing="8">
                                            <Grid ColumnDefinitions="Auto,*,Auto"
                                                  ColumnSpacing="10">
                                                <Border Classes="status-dot"
                                                        Classes.current="{Binding IsManagedProvider}"
                                                        VerticalAlignment="Center"/>
                                                <StackPanel Grid.Column="1"
                                                            Spacing="2">
                                                    <TextBlock Text="{Binding ModelProvider}"
                                                               FontWeight="SemiBold"
                                                               TextTrimming="CharacterEllipsis"/>
                                                    <text:CodexText Text="{Binding State}"
                                                                    Role="Muted"/>
                                                </StackPanel>
                                                <StackPanel Grid.Column="2"
                                                            MinWidth="120"
                                                            HorizontalAlignment="Right"
                                                            Spacing="2">
                                                    <TextBlock Text="{Binding SessionFiles}"
                                                               FontWeight="SemiBold"
                                                               HorizontalAlignment="Right"/>
                                                    <text:CodexText Text="{i18n:Tr codexSessions.table.sessionFiles}"
                                                                    Role="Muted"
                                                                    HorizontalAlignment="Right"/>
                                                </StackPanel>
                                            </Grid>

                                            <Grid Grid.Row="1"
                                                  ColumnDefinitions="*,Auto"
                                                  ColumnSpacing="12">
                                                <ui:CodexProgress Minimum="0"
                                                                  Maximum="100"
                                                                  Value="{Binding SharePercent}"
                                                                  Size="Small"
                                                                  VerticalAlignment="Center"/>
                                                <StackPanel Grid.Column="1"
                                                            Orientation="Horizontal"
                                                            Spacing="6"
                                                            VerticalAlignment="Center">
                                                    <text:CodexText Text="{i18n:Tr codexSessions.table.indexEntries}"
                                                                    Role="Muted"/>
                                                    <TextBlock Text="{Binding ThreadIndexEntries}"
                                                               FontWeight="SemiBold"/>
                                                </StackPanel>
                                            </Grid>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </Grid>
                </Border>
            </Grid>
        </Grid>
    </ScrollViewer>
</UserControl>
