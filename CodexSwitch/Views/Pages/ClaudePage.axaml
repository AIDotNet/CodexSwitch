<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:CodexSwitch.ViewModels"
             xmlns:ui="using:CodexSwitch.Controls"
             xmlns:i18n="using:CodexSwitch.I18n"
             xmlns:lucide="using:Lucide.Avalonia"
             x:Class="CodexSwitch.Views.Pages.ClaudePage"
             x:Name="Root"
             x:DataType="vm:MainWindowViewModel">
    <ScrollViewer>
        <Grid Margin="24,12,24,24"
              ColumnDefinitions="1.05*,0.95*"
              RowDefinitions="Auto,*"
              ColumnSpacing="18"
              RowSpacing="18">
            <Grid ColumnDefinitions="*,Auto">
                <StackPanel Spacing="4">
                    <ui:CsText Text="{i18n:Tr claude.title}" Classes="title"/>
                    <ui:CsText Text="{Binding Endpoint}" Classes="muted"/>
                </StackPanel>
                <ui:CsButton Grid.Column="1"
                             Classes="outline compact"
                             Command="{Binding ShowProvidersCommand}"
                             Content="{i18n:Tr claude.backToProviders}"/>
            </Grid>

            <Border Grid.Row="1" Classes="dialog-section">
                <Grid RowDefinitions="Auto,*" RowSpacing="12">
                    <StackPanel Spacing="4">
                        <ui:CsText Text="{i18n:Tr claude.providers}" Classes="heading"/>
                        <ui:CsText Text="{i18n:Tr claude.providersDescription}"
                                   Classes="muted"/>
                    </StackPanel>

                    <ItemsControl Grid.Row="1" ItemsSource="{Binding ClaudeProviderRows}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate x:DataType="vm:ProviderListItem">
                                <Border Classes="route-row" Margin="0,0,0,12">
                                    <Grid ColumnDefinitions="Auto,*,Auto"
                                          RowDefinitions="Auto,Auto"
                                          ColumnSpacing="10"
                                          RowSpacing="6">
                                        <Border Width="38"
                                                Height="38"
                                                Grid.RowSpan="2"
                                                CornerRadius="10"
                                                Background="#26FFFFFF">
                                            <ui:CsImageIcon Path="{Binding IconPath}"
                                                            Width="21"
                                                            Height="21"
                                                            HorizontalAlignment="Center"
                                                            VerticalAlignment="Center"/>
                                        </Border>
                                        <StackPanel Grid.Column="1"
                                                    Grid.RowSpan="2"
                                                    Spacing="4">
                                            <StackPanel Orientation="Horizontal" Spacing="8">
                                                <ui:CsText Text="{Binding DisplayName}" FontWeight="SemiBold"/>
                                                <ui:CsBadge Padding="7,2">
                                                    <ui:CsText Text="{Binding Protocol}" Classes="muted" FontSize="11"/>
                                                </ui:CsBadge>
                                            </StackPanel>
                                            <ui:CsText Text="{Binding BaseUrl}"
                                                       Classes="muted"
                                                       TextTrimming="CharacterEllipsis"/>
                                            <ui:CsText Text="{Binding DefaultModel}"
                                                       Classes="muted"
                                                       TextTrimming="CharacterEllipsis"/>
                                        </StackPanel>
                                        <ui:CsBadge Grid.Column="2"
                                                    Classes="success"
                                                    IsVisible="{Binding IsActive}">
                                            <ui:CsText Text="{i18n:Tr providers.active}"
                                                       Foreground="{StaticResource CsSuccessBrush}"
                                                       FontSize="11"
                                                       FontWeight="SemiBold"/>
                                        </ui:CsBadge>
                                        <StackPanel Grid.Row="1"
                                                    Grid.Column="2"
                                                    Orientation="Horizontal"
                                                    Spacing="8"
                                                    HorizontalAlignment="Right">
                                            <ui:CsButton Classes="outline compact"
                                                         Command="{Binding SelectCommand}"
                                                         CommandParameter="{Binding}"
                                                         Content="{i18n:Tr addProvider.setActive}"/>
                                            <ui:CsButton Classes="outline compact"
                                                         Command="{Binding EditCommand}"
                                                         CommandParameter="{Binding}"
                                                         Content="{i18n:Tr common.edit}"/>
                                        </StackPanel>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </Grid>
            </Border>

            <Border Grid.Row="1"
                    Grid.Column="1"
                    Classes="dialog-section">
                <StackPanel Spacing="16">
                    <StackPanel Spacing="4">
                        <ui:CsText Text="{i18n:Tr claude.settings}" Classes="heading"/>
                        <ui:CsText Text="{i18n:Tr claude.settingsDescription}"
                                   Classes="muted"/>
                    </StackPanel>

                    <ui:CsField Label="{i18n:Tr claude.model}">
                        <StackPanel Spacing="10">
                            <ui:CsInput Text="{Binding ClaudeCodeModel, Mode=TwoWay}"
                                        PlaceholderText="{i18n:Tr claude.model}"/>
                            <ItemsControl ItemsSource="{Binding ClaudeCodeModelOptions}">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <WrapPanel/>
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <ui:CsButton Classes="outline compact"
                                                     Margin="0,0,8,8"
                                                     Command="{Binding #Root.DataContext.SelectClaudeCodeModelCommand}"
                                                     CommandParameter="{Binding}"
                                                     Content="{Binding}"/>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </ui:CsField>

                    <StackPanel Spacing="12">
                        <ui:CsSwitch Content="{i18n:Tr claude.think}"
                                     IsChecked="{Binding ClaudeCodeThinkEnabled, Mode=TwoWay}"/>
                        <ui:CsSwitch Content="{i18n:Tr claude.skipDangerousPrompt}"
                                     IsChecked="{Binding ClaudeCodeSkipDangerousModePermissionPrompt, Mode=TwoWay}"/>
                        <ui:CsSwitch Content="{i18n:Tr claude.oneMillionContext}"
                                     IsChecked="{Binding ClaudeCodeOneMillionContextEnabled, Mode=TwoWay}"
                                     IsEnabled="{Binding IsClaudeOneMillionContextAvailable}"/>
                    </StackPanel>

                    <ui:CsButton Classes="compact"
                                 Command="{Binding SaveClaudeCodeSettingsCommand}"
                                 HorizontalAlignment="Left">
                        <StackPanel Orientation="Horizontal" Spacing="7">
                            <lucide:LucideIcon Kind="Save" Size="14" StrokeWidth="2"/>
                            <TextBlock Text="{i18n:Tr claude.saveSettings}"/>
                        </StackPanel>
                    </ui:CsButton>
                </StackPanel>
            </Border>
        </Grid>
    </ScrollViewer>
</UserControl>
