<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:CodexSwitch.ViewModels"
             xmlns:ui="using:CodexSwitch.Controls"
             xmlns:i18n="using:CodexSwitch.I18n"
             xmlns:lucide="using:Lucide.Avalonia"
             x:Class="CodexSwitch.Views.Pages.ProvidersPage"
             x:DataType="vm:MainWindowViewModel">
    <ScrollViewer>
        <Grid Margin="24,12,24,24"
              RowDefinitions="Auto,*"
              RowSpacing="18"
              PointerPressed="ProviderContextHost_OnPointerPressed">
            <Grid ColumnDefinitions="*,Auto">
                <StackPanel Spacing="4">
                    <ui:CsText Text="{i18n:Tr providers.title}" Classes="title"/>
                    <ui:CsText Text="{Binding ProxyStatus}" Classes="muted"/>
                </StackPanel>
                <ui:CsBadge Grid.Column="1" VerticalAlignment="Top">
                    <ui:CsText Text="{Binding Endpoint}" Classes="muted"/>
                </ui:CsBadge>
            </Grid>

            <ItemsControl Grid.Row="1" ItemsSource="{Binding ProviderRows}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate x:DataType="vm:ProviderListItem">
                        <Grid Classes="provider-list-row"
                              ColumnDefinitions="*,Auto"
                              ColumnSpacing="10"
                              Margin="0,0,0,10">
                            <ui:CsProviderCard Command="{Binding SelectCommand}"
                                               CommandParameter="{Binding}"
                                               Classes.active="{Binding IsActive}">
                                <Grid ColumnDefinitions="Auto,Auto,*,Auto"
                                      RowDefinitions="Auto,Auto"
                                      ColumnSpacing="12"
                                      RowSpacing="6">
                                    <Border Grid.RowSpan="2"
                                            Classes="provider-drag-handle"
                                            PointerPressed="ProviderDragHandle_OnPointerPressed"
                                            PointerMoved="ProviderDragHandle_OnPointerMoved"
                                            PointerReleased="ProviderDragHandle_OnPointerReleased"
                                            PointerCaptureLost="ProviderDragHandle_OnPointerCaptureLost"
                                            VerticalAlignment="Stretch">
                                        <lucide:LucideIcon Kind="GripVertical"
                                                           Size="18"
                                                           StrokeWidth="2"/>
                                    </Border>
                                    <Border Width="40"
                                            Height="40"
                                            Grid.Column="1"
                                            Grid.RowSpan="2"
                                            CornerRadius="10"
                                            Background="#26FFFFFF">
                                        <ui:CsImageIcon Path="{Binding IconPath}"
                                                        Width="22"
                                                        Height="22"
                                                        HorizontalAlignment="Center"
                                                        VerticalAlignment="Center"/>
                                    </Border>
                                    <StackPanel Grid.Column="2"
                                                Grid.RowSpan="2"
                                                Spacing="5"
                                                VerticalAlignment="Center">
                                        <StackPanel Orientation="Horizontal" Spacing="8">
                                            <ui:CsText Text="{Binding DisplayName}" FontWeight="SemiBold"/>
                                            <ui:CsBadge Padding="7,2">
                                                <ui:CsText Text="{Binding Protocol}" Classes="muted" FontSize="11"/>
                                            </ui:CsBadge>
                                        </StackPanel>
                                        <ui:CsText Text="{Binding BaseUrl}"
                                                   Classes="muted"
                                                   TextTrimming="CharacterEllipsis"/>
                                    </StackPanel>
                                    <ui:CsBadge Grid.Column="3"
                                                Classes="success"
                                                IsVisible="{Binding IsActive}"
                                                VerticalAlignment="Top">
                                        <ui:CsText Text="{i18n:Tr providers.active}"
                                                   Foreground="{StaticResource CsSuccessBrush}"
                                                   FontSize="11"
                                                   FontWeight="SemiBold"/>
                                    </ui:CsBadge>
                                    <Border Grid.Row="1"
                                            Grid.Column="3"
                                            Classes="provider-usage"
                                            Classes.success="{Binding IsUsageValid}"
                                            Classes.error="{Binding IsUsageError}"
                                            Classes.refreshing="{Binding IsUsageRefreshing}"
                                            IsVisible="{Binding HasUsageInfo}"
                                            ToolTip.Tip="{Binding UsageToolTip}"
                                            HorizontalAlignment="Right"
                                            VerticalAlignment="Bottom">
                                        <Grid ColumnDefinitions="Auto,*"
                                              RowDefinitions="Auto,Auto,Auto"
                                              ColumnSpacing="7"
                                              MinWidth="132"
                                              MaxWidth="184">
                                            <Border Grid.RowSpan="3"
                                                    Classes="usage-status-dot"
                                                    Classes.success="{Binding IsUsageValid}"
                                                    Classes.error="{Binding IsUsageError}"
                                                    Classes.refreshing="{Binding IsUsageRefreshing}"
                                                    VerticalAlignment="Top"
                                                    Margin="0,5,0,0"/>
                                            <ui:CsText Grid.Column="1"
                                                       Text="{Binding UsageSummary}"
                                                       Classes="provider-usage-summary"
                                                       TextAlignment="Right"
                                                       TextTrimming="CharacterEllipsis"/>
                                            <ui:CsText Grid.Row="1"
                                                       Grid.Column="1"
                                                       Text="{Binding UsageMeta}"
                                                       Classes="provider-usage-meta"
                                                       TextAlignment="Right"
                                                       TextTrimming="CharacterEllipsis"/>
                                            <ui:CsText Grid.Row="2"
                                                       Grid.Column="1"
                                                       Text="{Binding UsageResetText}"
                                                       Classes="provider-usage-meta"
                                                       TextAlignment="Right"
                                                       TextTrimming="CharacterEllipsis"
                                                       IsVisible="{Binding HasUsageResetText}"/>
                                        </Grid>
                                    </Border>
                                </Grid>
                            </ui:CsProviderCard>
                            <ui:CsIconButton Grid.Column="1"
                                             Command="{Binding EditCommand}"
                                             CommandParameter="{Binding}"
                                             ToolTip.Tip="{i18n:Tr providers.edit}"
                                             VerticalAlignment="Center">
                                <lucide:LucideIcon Kind="Pencil" Size="16" StrokeWidth="2"/>
                            </ui:CsIconButton>
                        </Grid>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </Grid>
    </ScrollViewer>
</UserControl>
