<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:CodexSwitch.ViewModels"
             xmlns:ui="using:CodexSwitch.Controls"
             xmlns:i18n="using:CodexSwitch.I18n"
             xmlns:lucide="using:Lucide.Avalonia"
             x:Class="CodexSwitch.Views.Pages.ModelsPage"
             x:Name="Root"
             x:DataType="vm:MainWindowViewModel">
    <ScrollViewer>
        <Grid Margin="24,12,24,24"
              RowDefinitions="Auto,Auto,*"
              RowSpacing="14">
            <Grid ColumnDefinitions="*,Auto">
                <StackPanel Spacing="4">
                    <ui:CsText Text="{i18n:Tr models.title}" Classes="title"/>
                    <ui:CsText Text="{i18n:Tr models.description}"
                               Classes="muted"/>
                </StackPanel>
                <ui:CsButton Grid.Column="1"
                             Classes="compact"
                             Command="{Binding AddPricingModelCommand}"
                             VerticalAlignment="Top">
                    <StackPanel Orientation="Horizontal" Spacing="7">
                        <lucide:LucideIcon Kind="Plus" Size="14" StrokeWidth="2"/>
                        <TextBlock Text="{i18n:Tr models.add}"/>
                    </StackPanel>
                </ui:CsButton>
            </Grid>

            <ui:CsPanel Grid.Row="1" Padding="14">
                <Grid ColumnDefinitions="*,Auto" ColumnSpacing="12">
                    <StackPanel Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
                        <Border Width="34"
                                Height="34"
                                CornerRadius="10"
                                Background="#1734D399"
                                BorderBrush="#2634D399"
                                BorderThickness="1">
                            <lucide:LucideIcon Kind="BookOpenCheck"
                                               Size="17"
                                               StrokeWidth="2"
                                               Foreground="#34D399"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center"/>
                        </Border>
                        <StackPanel Spacing="2">
                            <ui:CsText Text="{i18n:Tr models.catalog.title}" FontWeight="SemiBold"/>
                            <ui:CsText Text="{i18n:Tr models.catalog.description}" Classes="muted"/>
                        </StackPanel>
                    </StackPanel>
                    <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                        <ui:CsBadge>
                            <ui:CsText Text="{Binding PricingUnitText}" Classes="muted"/>
                        </ui:CsBadge>
                        <ui:CsBadge>
                            <ui:CsText Text="{Binding ModelCatalogCountText}" Classes="muted"/>
                        </ui:CsBadge>
                    </StackPanel>
                </Grid>
            </ui:CsPanel>

            <ItemsControl Grid.Row="2" ItemsSource="{Binding ModelCatalogRows}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate x:DataType="vm:ModelCatalogItem">
                        <ui:CsModelCard Margin="0,0,0,10">
                            <Grid ColumnDefinitions="2.1*,3.5*,Auto"
                                  ColumnSpacing="14">
                                <StackPanel Orientation="Horizontal"
                                            Spacing="12"
                                            VerticalAlignment="Center">
                                    <Border Classes="model-icon-shell">
                                        <ui:CsImageIcon Path="{Binding IconPath}"
                                                        Width="24"
                                                        Height="24"
                                                        HorizontalAlignment="Center"
                                                        VerticalAlignment="Center"/>
                                    </Border>
                                    <StackPanel Spacing="5" MinWidth="0">
                                        <StackPanel Orientation="Horizontal" Spacing="8">
                                            <ui:CsText Text="{Binding DisplayName}"
                                                       FontWeight="SemiBold"
                                                       TextTrimming="CharacterEllipsis"/>
                                            <ui:CsBadge Padding="7,2">
                                                <ui:CsText Text="{Binding IconSlug}" Classes="muted" FontSize="11"/>
                                            </ui:CsBadge>
                                        </StackPanel>
                                        <ui:CsText Text="{Binding Id}"
                                                   Classes="muted"
                                                   TextTrimming="CharacterEllipsis"/>
                                        <ui:CsText Text="{Binding AliasesText}"
                                                   Classes="muted"
                                                   TextTrimming="CharacterEllipsis"
                                                   ToolTip.Tip="{Binding AliasesText}"/>
                                        <ui:CsText Text="{Binding ProvidersText}"
                                                   Classes="muted"
                                                   TextTrimming="CharacterEllipsis"
                                                   ToolTip.Tip="{Binding ProvidersText}"/>
                                    </StackPanel>
                                </StackPanel>

                                <Grid Grid.Column="1"
                                      ColumnDefinitions="*,*,*,*,*"
                                      ColumnSpacing="8">
                                    <ui:CsPriceChip Classes="input">
                                        <Grid RowDefinitions="Auto,Auto,Auto" RowSpacing="2">
                                            <ui:CsText Text="{i18n:Tr models.price.input}" Classes="muted" FontSize="11"/>
                                            <ui:CsText Grid.Row="1" Text="{Binding InputPriceText}" FontWeight="SemiBold"/>
                                            <ui:CsText Grid.Row="2" Text="{Binding InputTierText}" Classes="muted" FontSize="11"/>
                                        </Grid>
                                    </ui:CsPriceChip>
                                    <ui:CsPriceChip Grid.Column="1" Classes="cache">
                                        <Grid RowDefinitions="Auto,Auto,Auto" RowSpacing="2">
                                            <ui:CsText Text="{i18n:Tr models.price.cacheRead}" Classes="muted" FontSize="11"/>
                                            <ui:CsText Grid.Row="1" Text="{Binding CachedInputPriceText}" FontWeight="SemiBold"/>
                                            <ui:CsText Grid.Row="2" Text="{i18n:Tr models.price.cacheHit}" Classes="muted" FontSize="11"/>
                                        </Grid>
                                    </ui:CsPriceChip>
                                    <ui:CsPriceChip Grid.Column="2" Classes="create">
                                        <Grid RowDefinitions="Auto,Auto,Auto" RowSpacing="2">
                                            <ui:CsText Text="{i18n:Tr models.price.cacheCreate}" Classes="muted" FontSize="11"/>
                                            <ui:CsText Grid.Row="1" Text="{Binding CacheCreationInputPriceText}" FontWeight="SemiBold"/>
                                            <ui:CsText Grid.Row="2" Text="{i18n:Tr models.price.claudeWrite}" Classes="muted" FontSize="11"/>
                                        </Grid>
                                    </ui:CsPriceChip>
                                    <ui:CsPriceChip Grid.Column="3" Classes="output">
                                        <Grid RowDefinitions="Auto,Auto,Auto" RowSpacing="2">
                                            <ui:CsText Text="{i18n:Tr models.price.output}" Classes="muted" FontSize="11"/>
                                            <ui:CsText Grid.Row="1" Text="{Binding OutputPriceText}" FontWeight="SemiBold"/>
                                            <ui:CsText Grid.Row="2" Text="{Binding OutputTierText}" Classes="muted" FontSize="11"/>
                                        </Grid>
                                    </ui:CsPriceChip>
                                    <ui:CsPriceChip Grid.Column="4" Classes="fast">
                                        <Grid RowDefinitions="Auto,Auto,Auto" RowSpacing="2">
                                            <ui:CsText Text="{i18n:Tr models.price.fast}" Classes="muted" FontSize="11"/>
                                            <ui:CsText Grid.Row="1" Text="{Binding FastMultiplierText}" FontWeight="SemiBold"/>
                                            <ui:CsText Grid.Row="2" Text="{i18n:Tr models.price.multiplier}" Classes="muted" FontSize="11"/>
                                        </Grid>
                                    </ui:CsPriceChip>
                                </Grid>

                                <StackPanel Grid.Column="2"
                                            Orientation="Horizontal"
                                            Spacing="8"
                                            VerticalAlignment="Center">
                                    <ui:CsIconButton Command="{Binding #Root.DataContext.EditPricingModelCommand}"
                                                     CommandParameter="{Binding}"
                                                     ToolTip.Tip="{i18n:Tr models.edit}">
                                        <lucide:LucideIcon Kind="Pencil" Size="15" StrokeWidth="2"/>
                                    </ui:CsIconButton>
                                    <ui:CsIconButton Classes="danger"
                                                     Command="{Binding #Root.DataContext.RequestRemovePricingModelCommand}"
                                                     CommandParameter="{Binding}"
                                                     ToolTip.Tip="{i18n:Tr models.delete}">
                                        <lucide:LucideIcon Kind="Trash2" Size="15" StrokeWidth="2"/>
                                    </ui:CsIconButton>
                                </StackPanel>
                            </Grid>
                        </ui:CsModelCard>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </Grid>
    </ScrollViewer>
</UserControl>
