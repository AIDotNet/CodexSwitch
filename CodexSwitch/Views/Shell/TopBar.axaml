<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:CodexSwitch.ViewModels"
             xmlns:ui="using:CodexSwitch.Controls"
             xmlns:i18n="using:CodexSwitch.I18n"
             xmlns:lucide="using:Lucide.Avalonia"
             x:Class="CodexSwitch.Views.Shell.TopBar"
             x:DataType="vm:MainWindowViewModel">
    <Grid Margin="24,14,24,10"
          ColumnDefinitions="Auto,*,Auto"
          ColumnSpacing="16">
        <StackPanel Orientation="Horizontal"
                    Spacing="10"
                    VerticalAlignment="Center">
            <ui:CsImageIcon Path="{Binding CodexIconPath}"
                            Width="22"
                            Height="22"/>
            <ui:CsText Text="{i18n:Tr app.name}"
                       FontSize="18"
                       FontWeight="SemiBold"/>
        </StackPanel>

        <ui:CsAppSwitcher Grid.Column="1"
                          HorizontalAlignment="Center"
                          VerticalAlignment="Center">
            <ItemsControl ItemsSource="{Binding ClientApps}">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <StackPanel Orientation="Horizontal" Spacing="4"/>
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate x:DataType="vm:ClientAppItem">
                        <ui:CsSegmentedButton IsSelected="{Binding IsSelected}"
                                              Command="{Binding SelectCommand}"
                                              CommandParameter="{Binding}">
                            <StackPanel Orientation="Horizontal" Spacing="7">
                                <ui:CsImageIcon Path="{Binding IconPath}" Width="18" Height="18"/>
                                <TextBlock Text="{Binding Name}"/>
                            </StackPanel>
                        </ui:CsSegmentedButton>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ui:CsAppSwitcher>

        <StackPanel Grid.Column="2"
                    Orientation="Horizontal"
                    Spacing="8"
                    VerticalAlignment="Center">
            <ui:CsIconButton Command="{Binding ToggleProxyCommand}"
                             ToolTip.Tip="{Binding ServiceStateText}">
                <lucide:LucideIcon Kind="Power" Size="17" StrokeWidth="2"/>
            </ui:CsIconButton>
            <ui:CsIconButton Command="{Binding ShowUsageCommand}"
                             ToolTip.Tip="{i18n:Tr nav.usage}">
                <lucide:LucideIcon Kind="ChartNoAxesColumnIncreasing" Size="17" StrokeWidth="2"/>
            </ui:CsIconButton>
            <ui:CsIconButton Command="{Binding ShowModelsCommand}"
                             ToolTip.Tip="{i18n:Tr nav.models}">
                <lucide:LucideIcon Kind="BrainCircuit" Size="17" StrokeWidth="2"/>
            </ui:CsIconButton>
            <ui:CsIconButton Command="{Binding OpenSettingsCommand}"
                             ToolTip.Tip="{i18n:Tr nav.settings}">
                <lucide:LucideIcon Kind="Settings" Size="17" StrokeWidth="2"/>
            </ui:CsIconButton>
            <ui:CsIconButton Classes="primary"
                             Command="{Binding AddProviderCommand}"
                             ToolTip.Tip="{i18n:Tr nav.addProvider}">
                <lucide:LucideIcon Kind="Plus" Size="18" StrokeWidth="2.2"/>
            </ui:CsIconButton>
        </StackPanel>
    </Grid>
</UserControl>
