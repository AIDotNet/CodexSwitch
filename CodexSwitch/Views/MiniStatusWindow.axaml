<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:CodexSwitch.ViewModels"
        xmlns:ui="using:CodexSwitch.Controls"
        x:Class="CodexSwitch.Views.MiniStatusWindow"
        x:DataType="vm:MainWindowViewModel"
        Width="400"
        Height="34"
        MinWidth="400"
        MaxWidth="400"
        CanResize="False"
        ShowInTaskbar="False"
        WindowDecorations="None"
        WindowStartupLocation="Manual"
        Background="Transparent"
        Topmost="True"
        PointerEntered="OnPointerEntered"
        PointerExited="OnPointerExited"
        PointerPressed="OnPointerPressed"
        PointerReleased="OnPointerReleased">
    <Border CornerRadius="8"
            ClipToBounds="True"
            BorderBrush="#4D334252"
            BorderThickness="1"
            Background="#F0121720"
            Padding="10,5">
        <StackPanel Spacing="2">
            <Grid ColumnDefinitions="24,Auto,32,Auto,*,Auto,*"
                  Height="22"
                  ColumnSpacing="7"
                  VerticalAlignment="Center">
                <Border Width="24"
                        Height="24"
                        CornerRadius="6"
                        Background="#2633404C">
                    <ui:CsImageIcon Path="{Binding MiniStatusProviderIconPath}"
                                    Width="20"
                                    Height="20"
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Center"/>
                </Border>
                <TextBlock Grid.Column="1"
                           Text="RPM"
                           Foreground="#CBD5E1"
                           FontSize="13"
                           VerticalAlignment="Center"/>
                <TextBlock Grid.Column="2"
                           Text="{Binding MiniStatusRpmText}"
                           Foreground="#F8FAFC"
                           FontSize="15"
                           FontWeight="SemiBold"
                           TextTrimming="CharacterEllipsis"
                           VerticalAlignment="Center"/>
                <TextBlock Grid.Column="3"
                           Text="&#x5165;"
                           Foreground="#CBD5E1"
                           FontSize="13"
                           VerticalAlignment="Center"/>
                <TextBlock Grid.Column="4"
                           Text="{Binding MiniStatusInputTokensText}"
                           Foreground="#F8FAFC"
                           FontSize="15"
                           FontWeight="SemiBold"
                           TextTrimming="CharacterEllipsis"
                           VerticalAlignment="Center"/>
                <TextBlock Grid.Column="5"
                           Text="&#x51FA;"
                           Foreground="#CBD5E1"
                           FontSize="13"
                           VerticalAlignment="Center"/>
                <TextBlock Grid.Column="6"
                           Text="{Binding MiniStatusOutputTokensText}"
                           Foreground="#F8FAFC"
                           FontSize="15"
                           FontWeight="SemiBold"
                           TextTrimming="CharacterEllipsis"
                           VerticalAlignment="Center"/>
            </Grid>

            <StackPanel Orientation="Horizontal"
                        Spacing="12"
                        IsVisible="{Binding MiniStatusHasQuotaRow}"
                        Margin="32,0,0,0"
                        VerticalAlignment="Center">
                <TextBlock Foreground="#F8FAFC"
                           FontSize="14"
                           FontWeight="SemiBold"
                           IsVisible="{Binding MiniStatusHasDailyQuota}">
                    <Run Text="&#x65E5; "/>
                    <Run Text="{Binding MiniStatusDailyQuotaText}"/>
                </TextBlock>
                <TextBlock Foreground="#F8FAFC"
                           FontSize="14"
                           FontWeight="SemiBold"
                           IsVisible="{Binding MiniStatusHasWeeklyQuota}">
                    <Run Text="&#x5468; "/>
                    <Run Text="{Binding MiniStatusWeeklyQuotaText}"/>
                </TextBlock>
                <TextBlock Foreground="#F8FAFC"
                           FontSize="14"
                           FontWeight="SemiBold"
                           IsVisible="{Binding MiniStatusHasPackageQuota}">
                    <Run Text="&#x5305; "/>
                    <Run Text="{Binding MiniStatusPackageQuotaText}"/>
                </TextBlock>
            </StackPanel>
        </StackPanel>
    </Border>
</Window>
