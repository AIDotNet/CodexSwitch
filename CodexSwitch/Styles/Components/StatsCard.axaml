<Styles xmlns="https://github.com/avaloniaui"
        xmlns:ui="using:CodexSwitch.Controls">
    <Style Selector="ui|CsStatsCard">
        <Setter Property="MinHeight" Value="96"/>
        <Setter Property="Padding" Value="16"/>
        <Setter Property="Template">
            <ControlTemplate>
                <Border Background="{StaticResource CsCardBrush}"
                        BorderBrush="{StaticResource CsBorderBrush}"
                        BorderThickness="1"
                        CornerRadius="{StaticResource CsRadiusXl}"
                        Padding="{TemplateBinding Padding}">
                    <Border.Transitions>
                        <Transitions>
                            <BrushTransition Property="Background" Duration="0:0:0.14"/>
                            <BrushTransition Property="BorderBrush" Duration="0:0:0.14"/>
                        </Transitions>
                    </Border.Transitions>
                    <ContentPresenter Content="{TemplateBinding Content}"/>
                </Border>
            </ControlTemplate>
        </Setter>
    </Style>
    <Style Selector="ui|CsStatsCard:pointerover">
        <Setter Property="Background" Value="{StaticResource CsProviderCardHoverBrush}"/>
        <Setter Property="BorderBrush" Value="{StaticResource CsHoverBorderBrush}"/>
    </Style>
</Styles>
