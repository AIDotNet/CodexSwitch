<Styles xmlns="https://github.com/avaloniaui"
        xmlns:ui="using:CodexSwitch.Controls">
    <Style Selector="ui|CsDialog">
        <Setter Property="Opacity" Value="1"/>
        <Setter Property="Transitions">
            <Transitions>
                <DoubleTransition Property="Opacity" Duration="0:0:0.14"/>
            </Transitions>
        </Setter>
        <Setter Property="Template">
            <ControlTemplate>
                <Grid Background="#B3000000">
                    <ContentPresenter Content="{TemplateBinding Content}"/>
                </Grid>
            </ControlTemplate>
        </Setter>
    </Style>

    <Style Selector="Border.dialog-card">
        <Setter Property="Background" Value="{StaticResource CsDialogCardBrush}"/>
        <Setter Property="BorderBrush" Value="{StaticResource CsBorderBrush}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="CornerRadius" Value="16"/>
        <Setter Property="Padding" Value="20"/>
        <Setter Property="BoxShadow" Value="0 24 72 0 #99000000"/>
        <Setter Property="Transitions">
            <Transitions>
                <BrushTransition Property="Background" Duration="0:0:0.14"/>
                <BrushTransition Property="BorderBrush" Duration="0:0:0.14"/>
                <DoubleTransition Property="Opacity" Duration="0:0:0.14"/>
            </Transitions>
        </Setter>
    </Style>
    <Style Selector="Border.dialog-card:pointerover">
        <Setter Property="BorderBrush" Value="{StaticResource CsHoverBorderBrush}"/>
    </Style>

    <Style Selector="Border.dialog-section">
        <Setter Property="Background" Value="{StaticResource CsDialogSectionBrush}"/>
        <Setter Property="BorderBrush" Value="{StaticResource CsBorderBrush}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="CornerRadius" Value="{StaticResource CsRadiusLg}"/>
        <Setter Property="Padding" Value="14"/>
        <Setter Property="Transitions">
            <Transitions>
                <BrushTransition Property="Background" Duration="0:0:0.14"/>
                <BrushTransition Property="BorderBrush" Duration="0:0:0.14"/>
            </Transitions>
        </Setter>
    </Style>
    <Style Selector="Border.dialog-section:pointerover">
        <Setter Property="Background" Value="{StaticResource CsDialogSectionHoverBrush}"/>
        <Setter Property="BorderBrush" Value="{StaticResource CsHoverBorderBrush}"/>
    </Style>

    <Style Selector="Border.route-row">
        <Setter Property="Background" Value="{StaticResource CsRouteRowBrush}"/>
        <Setter Property="BorderBrush" Value="{StaticResource CsBorderBrush}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="CornerRadius" Value="{StaticResource CsRadiusLg}"/>
        <Setter Property="Padding" Value="12"/>
        <Setter Property="Transitions">
            <Transitions>
                <BrushTransition Property="Background" Duration="0:0:0.14"/>
                <BrushTransition Property="BorderBrush" Duration="0:0:0.14"/>
            </Transitions>
        </Setter>
    </Style>
    <Style Selector="Border.route-row:pointerover">
        <Setter Property="Background" Value="{StaticResource CsRouteRowHoverBrush}"/>
        <Setter Property="BorderBrush" Value="#334EA8FF"/>
    </Style>
</Styles>
